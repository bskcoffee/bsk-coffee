# IP ของเครื่องพิมพ์ ES-9960 บน WiFi (ดูได้จากหน้าจอเครื่องพิมพ์หรือ router)
PRINTER_IP=192.168.1.100

# MAC address ของเครื่องพิมพ์ label ตัวจริง (ดูจากหน้าจอเครื่องพิมพ์ หรือรัน `arp -a` ตอนเครื่องพิมพ์ออนไลน์)
# ใช้ยืนยันตัวตนก่อนสลับ IP อัตโนมัติ (auto-discovery) — กันสลับไปเครื่องอื่นที่บังเอิญเปิดพอร์ตเดียวกัน
# ถ้าไม่ตั้งไว้ ระบบจะยังทำงานได้แต่ auto-discovery จะไม่ยืนยันตัวตนก่อนสลับ (เสี่ยงสลับผิดเครื่อง)
PRINTER_MAC=

# Port เครื่องพิมพ์ (ES-9960 ใช้ 9100 เป็น default)
PRINTER_PORT=9100

# Port ของ print server นี้ (ต้องตรงกับที่ตั้งใน BSK label settings)
SERVER_PORT=3001
