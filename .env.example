# ============================================================
# Cocoa House — Environment Variables
# ============================================================
# วิธีใช้:
#   1. Copy ไฟล์นี้ แล้วเปลี่ยนชื่อเป็น .env
#   2. ใส่ค่าจริงจาก Supabase Dashboard
#   3. ห้าม commit ไฟล์ .env ขึ้น Git (ดู .gitignore)
# ============================================================

# Supabase Project URL
# ดูได้ที่: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase Anon (Public) Key
# ดูได้ที่: Supabase Dashboard → Project Settings → API → Project API Keys → anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx
