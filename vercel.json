{
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/report-send",    "schedule": "30 9 * * *"  },
    { "path": "/api/report-weekly",  "schedule": "30 9 * * 1"  },
    { "path": "/api/report-monthly", "schedule": "30 9 1 * *"  }
  ]
}
