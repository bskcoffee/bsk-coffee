{
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/report-send",    "schedule": "30 5 * * *"  },
    { "path": "/api/report-weekly",  "schedule": "0 6 * * 1"   },
    { "path": "/api/report-monthly", "schedule": "0 7 1 * *"   }
  ]
}
